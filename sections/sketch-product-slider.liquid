{% comment %}
  SKETCH PRODUCT SLIDER – FINAL RESPONSIVE INFINITE VERSION
{% endcomment %}

<section class="sk-product-slider-wrapper" id="sk-slider-{{ section.id }}">
  <div class="sk-ps-container">

    <div class="sk-ps-header">
      {% if section.settings.title != blank %}
        <h2 class="sk-ps-heading">{{ section.settings.title }}</h2>
      {% endif %}
      {% if section.settings.subtitle != blank %}
        <a href="{{ section.settings.subtitle_link | default: section.settings.collection.url }}" class="sk-ps-sublink">
          {{ section.settings.subtitle }}
        </a>
      {% endif %}
    </div>

    <div class="sk-ps-carousel">

      <button class="sk-ps-nav sk-ps-prev" aria-label="Previous">‹</button>

      <div class="sk-ps-track-wrapper">
        <div class="sk-ps-track">
          {% assign selected_collection = section.settings.collection %}

          {% if selected_collection != blank and selected_collection.products_count > 0 %}
            {% for product in selected_collection.products %}
              <div class="sk-ps-item">
                <a href="{{ product.url }}" class="sk-ps-card-link">
                  <div class="sk-ps-image-wrapper">
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      alt="{{ product.title | escape }}"
                      loading="lazy"
                      class="sk-ps-image">
                  </div>
                  <div class="sk-ps-info">
                    <h3 class="sk-ps-product-title">{{ product.title }}</h3>
                    <span class="sk-ps-product-price" style="color: {{ section.settings.price_color }};">
                      {{ product.price | money }}
                    </span>
                  </div>
                </a>
              </div>
            {% endfor %}
          {% endif %}
        </div>
      </div>

      <button class="sk-ps-nav sk-ps-next" aria-label="Next">›</button>

    </div>
  </div>
</section>

<style>
.sk-product-slider-wrapper {
  padding: 60px 0;
  background: #fff;
  font-family: Arial, sans-serif;
}

.sk-ps-container {
  max-width: 1240px;
  margin: auto;
  position: relative;
}

.sk-ps-header {
  text-align: center;
  margin-bottom: 40px;
}

.sk-ps-heading {
  font-size: 28px;
  font-weight: 600;
  text-transform: uppercase;
}

.sk-ps-sublink {
  font-size: 12px;
  text-transform: uppercase;
  text-decoration: none;
  color: #666;
}

.sk-ps-carousel {
  position: relative;
}

.sk-ps-track-wrapper {
  overflow: hidden;
}

.sk-ps-track {
  display: flex;
  gap: 30px;
  transition: transform 0.5s ease;
}

.sk-ps-item {
  flex: 0 0 calc(25% - 22.5px);
}

.sk-ps-image-wrapper {
  background: #f0f0f0;
  aspect-ratio: 4/5;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.sk-ps-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: transform 0.4s ease;
}

.sk-ps-card-link:hover .sk-ps-image {
  transform: scale(1.05);
}

.sk-ps-info {
  text-align: center;
  margin-top: 10px;
}

.sk-ps-product-title {
  font-size: 11px;
  text-transform: uppercase;
  font-weight: 600;
}

.sk-ps-product-price {
  font-size: 13px;
  font-weight: 600;
}

/* Navigation Buttons */
.sk-ps-nav {
  position: absolute;
  top: 45%;
  transform: translateY(-50%);
  width: 45px;
  height: 45px;
  background: transparent;
  color: #000000;
  border: 2px solid black;
  border-radius: 50%;
  font-size: 30px;
  cursor: pointer;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sk-ps-prev { left: -22px; }
.sk-ps-next { right: -22px; }

/* Tablet - 3 Cards */
@media(max-width:1024px){
  .sk-ps-item { 
    flex: 0 0 calc(33.33% - 20px); 
  }
  .sk-ps-nav{
    top: 107%;
    width: 30px;
    height: 30px;
    border: 1px solid black;
    font-size: 20px;
  }
  .sk-ps-prev { left: 45%; }
  .sk-ps-next { right: 45%; }
}

/* Mobile - 1 Card */
@media(max-width:480px){
  .sk-ps-item { 
    flex: 0 0 100%; 
  }
  .sk-ps-prev { left: 40%; }
  .sk-ps-next { right: 40%; }
  .sk-ps-image-wrapper{aspect-ratio: 5/5;}
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const slider = document.querySelector("#sk-slider-{{ section.id }}");
  if (!slider) return;

  const track = slider.querySelector(".sk-ps-track");
  const prev = slider.querySelector(".sk-ps-prev");
  const next = slider.querySelector(".sk-ps-next");

  let items = slider.querySelectorAll(".sk-ps-item");
  const gap = 30;

  if (items.length === 0) return;

  let position = 0;
  let itemWidth = 0;

  function calculateWidth() {
    items = slider.querySelectorAll(".sk-ps-item");
    itemWidth = items[0].offsetWidth + gap;
  }

  /* Clone once for infinite loop */
  if (!track.classList.contains("cloned")) {
    items.forEach(item => {
      const clone = item.cloneNode(true);
      track.appendChild(clone);
    });
    track.classList.add("cloned");
  }

  function moveNext() {
    position -= itemWidth;
    track.style.transform = `translateX(${position}px)`;

    if (Math.abs(position) >= itemWidth * items.length) {
      setTimeout(() => {
        track.style.transition = "none";
        position = 0;
        track.style.transform = "translateX(0px)";
        setTimeout(() => {
          track.style.transition = "transform 0.5s ease";
        }, 50);
      }, 500);
    }
  }

  function movePrev() {
    if (position === 0) {
      track.style.transition = "none";
      position = -itemWidth * items.length;
      track.style.transform = `translateX(${position}px)`;
      setTimeout(() => {
        track.style.transition = "transform 0.5s ease";
        position += itemWidth;
        track.style.transform = `translateX(${position}px)`;
      }, 50);
    } else {
      position += itemWidth;
      track.style.transform = `translateX(${position}px)`;
    }
  }

  next.addEventListener("click", moveNext);
  prev.addEventListener("click", movePrev);

  let auto = setInterval(moveNext, 3000);

  slider.addEventListener("mouseenter", () => clearInterval(auto));
  slider.addEventListener("mouseleave", () => {
    auto = setInterval(moveNext, 3000);
  });

  function handleResize() {
    calculateWidth();
    position = 0;
    track.style.transition = "none";
    track.style.transform = "translateX(0px)";
    setTimeout(() => {
      track.style.transition = "transform 0.5s ease";
    }, 50);
  }

  calculateWidth();
  window.addEventListener("resize", handleResize);

});
</script>

{% schema %}
{
  "name": "Sketch Slider",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "Featured Products" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "View All" },
    { "type": "url", "id": "subtitle_link", "label": "Subtitle Link" },
    { "type": "collection", "id": "collection", "label": "Select Collection" },
    { "type": "color", "id": "price_color", "label": "Price Color", "default": "#d93838" }
  ],
  "presets": [
    { "name": "Sketch Slider" }
  ]
}
{% endschema %}