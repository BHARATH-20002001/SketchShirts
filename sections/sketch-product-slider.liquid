{% comment %}
  SKETCH SHIRTS - PRODUCT CAROUSEL
  Reusable section for displaying a collection of products in a slider.
{% endcomment %}

<section class="sk-product-slider-wrapper" id="sk-slider-{{ section.id }}">
  <div class="sk-ps-container">
    
    {%- comment -%} Header Area {%- endcomment -%}
    <div class="sk-ps-header">
      {%- if section.settings.title != blank -%}
        <h2 class="sk-ps-heading">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <a href="{{ section.settings.subtitle_link | default: section.settings.collection.url }}" class="sk-ps-sublink">
          {{ section.settings.subtitle }}
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} Carousel Area {%- endcomment -%}
    <div class="sk-ps-carousel">
      
      <button class="sk-ps-nav sk-ps-prev" aria-label="Previous">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"/></svg>
      </button>

      <div class="sk-ps-track" id="sk-track-{{ section.id }}">
        {%- assign selected_collection = section.settings.collection -%}
        
        {%- if selected_collection != blank and selected_collection.products_count > 0 -%}
          {%- for product in selected_collection.products limit: section.settings.product_limit -%}
            <div class="sk-ps-item">
              <a href="{{ product.url }}" class="sk-ps-card-link">
                <div class="sk-ps-image-wrapper">
                  <img src="{{ product.featured_image | image_url: width: 600 }}" 
                       alt="{{ product.title | escape }}" 
                       loading="lazy" 
                       class="sk-ps-image">
                </div>
                <div class="sk-ps-info">
                  <h3 class="sk-ps-product-title">{{ product.title }}</h3>
                  <span class="sk-ps-product-price" style="color: {{ section.settings.price_color }};">
                    {{ product.price | money }}
                  </span>
                </div>
              </a>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- comment -%} Placeholder state for the theme editor {%- endcomment -%}
          {%- for i in (1..6) -%}
            <div class="sk-ps-item">
              <div class="sk-ps-card-link">
                <div class="sk-ps-image-wrapper" style="display: flex; align-items: center; justify-content: center; background: #f4f4f4;">
                  {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
                <div class="sk-ps-info">
                  <h3 class="sk-ps-product-title">Sample Product {{ i }}</h3>
                  <span class="sk-ps-product-price" style="color: {{ section.settings.price_color }};">€29,95</span>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      <button class="sk-ps-nav sk-ps-next" aria-label="Next">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg>
      </button>

    </div>
  </div>
</section>

<style>
/* Scoped Styles for Slider */
.sk-product-slider-wrapper {
  padding: 60px 0;
  background-color: #ffffff;
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.sk-ps-container {
  max-width: 1240px;
  margin: 0 auto;
  padding: 0 0px;
}

.sk-ps-header {
  text-align: center;
  margin-bottom: 40px;
}

.sk-ps-heading {
  font-size: 28px;
  font-weight: 600;
  text-transform: uppercase;
  margin: 0 0 10px 0;
  letter-spacing: 1px;
}

.sk-ps-sublink {
  font-size: 12px;
  text-transform: uppercase;
  color: #666;
  text-decoration: none;
  letter-spacing: 1.5px;
  transition: color 0.3s;
}

.sk-ps-sublink:hover {
  color: #000;
}

/* Carousel Layout */
.sk-ps-carousel {
  position: relative;
  display: flex;
  align-items: center;
}

.sk-ps-track {
  display: flex;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  gap: 30px;
  padding-bottom: 20px; /* Space for hidden scrollbar */
  width: 100%;
  -ms-overflow-style: none;  /* IE and Edge */
  scrollbar-width: none;  /* Firefox */
}

.sk-ps-track::-webkit-scrollbar {
  display: none; /* Hide scrollbar for Chrome, Safari and Opera */
}

.sk-ps-item {
  flex: 0 0 calc(25% - 22.5px); /* Show 4 items on desktop */
  scroll-snap-align: start;
}

/* Product Card Styling */
.sk-ps-card-link {
  text-decoration: none;
  color: inherit;
  display: block;
}

.sk-ps-image-wrapper {
  background-color: #f0f0f0; /* Light grey background from your image */
  aspect-ratio: 4 / 5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 15px;
  overflow: hidden;
}

.sk-ps-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  mix-blend-mode: multiply; /* Helps blend product images with white backgrounds into the grey */
  transition: transform 0.4s ease;
}

.sk-ps-card-link:hover .sk-ps-image {
  transform: scale(1.05);
}

.sk-ps-info {
  text-align: center;
}

.sk-ps-product-title {
  font-size: 11px;
  text-transform: uppercase;
  font-weight: 600;
  margin: 0 0 5px 0;
  letter-spacing: 0.5px;
}

.sk-ps-product-price {
  font-size: 13px;
  font-weight: 600;
}

/* Navigation Buttons */
.sk-ps-nav {
  position: absolute;
  top: 40%;
  transform: translateY(-50%);
  background: #ffffff;
  border: 1px solid #000;
  border-radius: 50%;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  z-index: 10;
  transition: all 0.3s ease;
}

.sk-ps-nav:hover {
  background: #000;
  color: #fff;
}

.sk-ps-nav svg {
  width: 20px;
  height: 20px;
}

.sk-ps-prev { left: -20px; }
.sk-ps-next { right: -20px; }

/* Responsive Adjustments */
@media (max-width: 1024px) {
  .sk-ps-item { flex: 0 0 calc(33.333% - 20px); } /* 3 items */
}
@media (max-width: 768px) {
  .sk-ps-item { flex: 0 0 calc(50% - 15px); } /* 2 items */
  .sk-ps-container { padding: 0 20px; }
  .sk-ps-prev { left: 0; }
  .sk-ps-next { right: 0; }
}
@media (max-width: 480px) {
  .sk-ps-item { flex: 0 0 100%; } /* 1 item */
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const sliderSection = document.getElementById('sk-slider-{{ section.id }}');
  if (!sliderSection) return;

  const track = sliderSection.querySelector('.sk-ps-track');
  const prevBtn = sliderSection.querySelector('.sk-ps-prev');
  const nextBtn = sliderSection.querySelector('.sk-ps-next');

  // Calculate the width of one item + its gap
  const getScrollAmount = () => {
    const item = track.querySelector('.sk-ps-item');
    return item ? item.offsetWidth + 30 : 0; // 30 is the gap
  };

  // Next Button Logic
  nextBtn.addEventListener('click', () => {
    const scrollAmount = getScrollAmount();
    const maxScroll = track.scrollWidth - track.clientWidth;
    
    // If at the end, jump back to start (Looping effect)
    if (track.scrollLeft >= maxScroll - 10) {
      track.scrollTo({ left: 0, behavior: 'smooth' });
    } else {
      track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    }
  });

  // Previous Button Logic
  prevBtn.addEventListener('click', () => {
    const scrollAmount = getScrollAmount();
    
    // If at the beginning, jump to end (Looping effect)
    if (track.scrollLeft <= 10) {
      track.scrollTo({ left: track.scrollWidth, behavior: 'smooth' });
    } else {
      track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    }
  });
});
</script>

{% schema %}
{
  "name": "Sketch Product Slider",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "POWER BOMBER"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle / Link Text",
      "default": "ALLE ANZEIGEN"
    },
    {
      "type": "url",
      "id": "subtitle_link",
      "label": "Subtitle Link",
      "info": "Leaves blank to automatically link to the selected collection."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 4,
      "max": 16,
      "step": 1,
      "label": "Maximum products to show",
      "default": 8
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price Color",
      "default": "#d93838"
    }
  ],
  "presets": [
    {
      "name": "Sketch Product Slider"
    }
  ]
}
{% endschema %}