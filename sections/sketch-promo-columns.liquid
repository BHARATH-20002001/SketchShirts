{% comment %}
  SKETCH SHIRTS - PROMO COLUMNS
  2-column layout for featuring new designs or specific categories.
{% endcomment %}

<section class="sk-promo-wrapper" id="sk-promo-{{ section.id }}">
  <div class="sk-promo-container">
    <div class="sk-promo-grid">
      
      {%- for block in section.blocks -%}
        <div class="sk-promo-item" {{ block.shopify_attributes }}>
          
          {%- comment -%} Image {%- endcomment -%}
          <div class="sk-promo-img-wrapper">
            <a href="{{ block.settings.link_url | default: '#' }}">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 800 }}" 
                     alt="{{ block.settings.heading | escape }}" 
                     loading="lazy" 
                     class="sk-promo-img">
              {%- else -%}
                <img src="https://placehold.co/800x400?text=Placeholder" alt="Placeholder image" loading="lazy" class="sk-promo-img">
              {%- endif -%}
            </a>
          </div>

          {%- comment -%} Text Content {%- endcomment -%}
          <div class="sk-promo-content">
            {%- if block.settings.heading != blank -%}
              <h3 class="sk-promo-heading">{{ block.settings.heading }}</h3>
            {%- endif -%}
            
            {%- if block.settings.text != blank -%}
              <p class="sk-promo-text">{{ block.settings.text }}</p>
            {%- endif -%}
            
            {%- if block.settings.link_label != blank -%}
              <a href="{{ block.settings.link_url | default: '#' }}" class="sk-promo-link">
                {{ block.settings.link_label }}
              </a>
            {%- endif -%}
          </div>
          
        </div>
      {%- endfor -%}

    </div>
  </div>
</section>

<style>
/* Scoped Styles */
.sk-promo-wrapper {
  padding: 60px 0;
  background-color: #ffffff;
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.sk-promo-container {
  width: 1240px;
  margin: 0 auto;
  padding: 0 0px;
}

.sk-promo-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 40px;
}

.sk-promo-img-wrapper {
  width: 100%;
  margin-bottom: 20px;
  overflow: hidden;
}

.sk-promo-img {
  width: 100%;
  height: 500px;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}

.sk-promo-img-wrapper a:hover .sk-promo-img {
  transform: scale(1.02);
}

.sk-promo-content {
  text-align: left;
}

.sk-promo-heading {
  font-size: 18px;
  font-weight: 700;
  text-transform: uppercase;
  margin: 0 0 10px 0;
  letter-spacing: 0.5px;
  color: #000000;
}

.sk-promo-text {
  font-size: 13px;
  line-height: 1.6;
  color: #555555;
  margin: 0 0 15px 0;
}

.sk-promo-link {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  color: #d93838; /* The red color from your screenshot */
  text-decoration: none;
  letter-spacing: 0.5px;
  transition: color 0.3s ease;
}

.sk-promo-link:hover {
  color: #000000;
}

/* Make images scale down neatly on mobile */
@media (max-width: 768px) {
  .sk-promo-grid {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .sk-promo-container {
    width: auto;
    padding: 0 20px;
  }
}
</style>

{% schema %}
{
  "name": "Sketch Promo Columns",
  "settings": [],
  "max_blocks": 2,
  "blocks": [
    {
      "type": "promo_column",
      "name": "Promo Column",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "#NEWDESIGN | WÖRTHERSEE 2021"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Since We Think The Wörthersee Meeting Is As Great As You Do, We Thought We Would Make A Special Design For It! And Here It Is :) Our Wörthersee 2021 Design!"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link Label",
          "default": "TO THE NEW DESIGN!"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sketch Promo Columns",
      "blocks": [
        {
          "type": "promo_column",
          "settings": {
            "heading": "#NEWDESIGN | WÖRTHERSEE 2021",
            "text": "Since We Think The Wörthersee Meeting Is As Great As You Do, We Thought We Would Make A Special Design For It! And Here It Is :) Our Wörthersee 2021 Design!",
            "link_label": "TO THE NEW DESIGN!"
          }
        },
        {
          "type": "promo_column",
          "settings": {
            "heading": "#NEWDESIGN | ITALIAN PREDATOR IN COLOR",
            "text": "This Super Sports Car Is Known By Everyone And Lives Up To Its Name :) It Is Extremely Loud And Runs Times Like No Other Car. Here We Have Brought 2 Designs Online Directly.",
            "link_label": "TO THE NEW DESIGN!"
          }
        }
      ]
    }
  ]
}
{% endschema %}