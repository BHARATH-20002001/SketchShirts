{% comment %}
  SketchShirts – Custom Product Detail Section
  - Left: thumbnail strip + sticky main image
  - Right: title, price, variant pickers, qty, buy buttons, description
{% endcomment %}

{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_images  = product.images
%}

<section class="skpd-wrapper" id="skpd-{{ section.id }}">
  <div class="skpd-container">

    {%- comment -%} ── LEFT: Media Column (sticky) ── {%- endcomment -%}
    <div class="skpd-media-col">
      <div class="skpd-media-sticky">

        {%- comment -%} Thumbnail Strip {%- endcomment -%}
        <div class="skpd-thumbnails" id="skpd-thumbs-{{ section.id }}">
          {%- for image in product_images limit: 6 -%}
            <button
              class="skpd-thumb {% if forloop.first %}skpd-thumb--active{% endif %}"
              data-index="{{ forloop.index0 }}"
              aria-label="{{ product.title | escape }} – image {{ forloop.index }}"
              type="button"
            >
              <img
                src="{{ image | image_url: width: 120 }}"
                alt="{{ image.alt | default: product.title | escape }}"
                loading="lazy"
                width="80"
                height="80"
              >
            </button>
          {%- endfor -%}
        </div>

        {%- comment -%} Main Image {%- endcomment -%}
        <div class="skpd-main-image" id="skpd-main-{{ section.id }}">
          {%- for image in product_images limit: 6 -%}
            <div
              class="skpd-slide {% if forloop.first %}skpd-slide--active{% endif %}"
              data-index="{{ forloop.index0 }}"
            >
              <img
                src="{{ image | image_url: width: 900 }}"
                alt="{{ image.alt | default: product.title | escape }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                class="skpd-main-img"
              >
            </div>
          {%- endfor -%}

          {%- if product_images.size == 0 -%}
            {{ 'product-1' | placeholder_svg_tag: 'skpd-placeholder-svg' }}
          {%- endif -%}
        </div>

      </div>
    </div>

    {%- comment -%} ── RIGHT: Product Details Column ── {%- endcomment -%}
    <div class="skpd-details-col">
      <div class="skpd-details-inner">

        {%- comment -%} Title {%- endcomment -%}
        <h1 class="skpd-title">{{ product.title }}</h1>

        {%- comment -%} Price {%- endcomment -%}
        <div class="skpd-price-wrap" id="skpd-price-{{ section.id }}">
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="skpd-price skpd-price--sale">{{ current_variant.price | money }}</span>
            <span class="skpd-price skpd-price--compare">{{ current_variant.compare_at_price | money }}</span>
          {%- else -%}
            <span class="skpd-price">{{ current_variant.price | money }}</span>
          {%- endif -%}
        </div>

        <hr class="skpd-divider">

        {%- comment -%} Variant Pickers {%- endcomment -%}
        {%- unless product.has_only_default_variant -%}
          <div class="skpd-variants" id="skpd-variants-{{ section.id }}">
            {%- for option in product.options_with_values -%}
              <div class="skpd-option-wrap">
                <label class="skpd-option-label" for="skpd-opt-{{ section.id }}-{{ forloop.index0 }}">
                  {{ option.name }}
                </label>
                <div class="skpd-select-wrap">
                  <select
                    id="skpd-opt-{{ section.id }}-{{ forloop.index0 }}"
                    class="skpd-select"
                    data-option-index="{{ forloop.index0 }}"
                    data-section-id="{{ section.id }}"
                  >
                    {%- for value in option.values -%}
                      <option
                        value="{{ value | escape }}"
                        {% if option.selected_value == value %}selected="selected"{% endif %}
                      >
                        {{ value | escape }}
                      </option>
                    {%- endfor -%}
                  </select>
                  <svg class="skpd-caret" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </div>
            {%- endfor -%}
          </div>

          <script type="application/json" id="skpd-variants-json-{{ section.id }}">
            {{ product.variants | json }}
          </script>
        {%- endunless -%}

        {%- comment -%} Quantity + Add to Cart {%- endcomment -%}
        <form
          action="/cart/add"
          method="post"
          class="skpd-atc-form"
          id="skpd-form-{{ section.id }}"
          enctype="multipart/form-data"
        >
          <input
            type="hidden"
            name="id"
            id="skpd-variant-id-{{ section.id }}"
            value="{{ current_variant.id }}"
          >

          <div class="skpd-qty-atc-row">
            <div class="skpd-qty-wrap">
              <button type="button" class="skpd-qty-btn skpd-qty-minus" aria-label="Decrease quantity">−</button>
              <input
                type="number"
                name="quantity"
                id="skpd-qty-{{ section.id }}"
                value="1"
                min="1"
                max="{{ current_variant.inventory_quantity | default: 999 }}"
                class="skpd-qty-input"
                aria-label="Quantity"
              >
              <button type="button" class="skpd-qty-btn skpd-qty-plus" aria-label="Increase quantity">+</button>
            </div>

            <button
              type="submit"
              name="add"
              class="skpd-atc-btn"
              id="skpd-atc-{{ section.id }}"
              {% unless current_variant.available %}disabled{% endunless %}
            >
              {%- if current_variant.available -%}
                {{ 'products.product.add_to_cart' | t }}
              {%- else -%}
                {{ 'products.product.sold_out' | t }}
              {%- endif -%}
            </button>
          </div>

          {%- comment -%} Dynamic Checkout Button (Buy Now) {%- endcomment -%}
          <div class="skpd-dynamic-checkout">
            {{ form | payment_button }}
          </div>
        </form>

        {%- comment -%} Product Description / Features {%- endcomment -%}
        {%- if product.description != blank -%}
          <div class="skpd-description rte">
            {{ product.description }}
          </div>
        {%- endif -%}

        {%- comment -%} Share Link {%- endcomment -%}
        <div class="skpd-share">
          <a
            href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url | append: product.url | url_encode }}"
            target="_blank"
            rel="noopener noreferrer"
            class="skpd-share-btn"
            aria-label="Share on Facebook"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
            Share
          </a>
        </div>

      </div>
    </div>
  </div>
</section>

{% comment %} ═══════ STYLES ═══════ {% endcomment %}
<style>
  /* ── Layout ── */
  .skpd-wrapper {
    padding: 32px 0 48px;
    background: var(--color-background, #fff);
    font-family: var(--font-body--family, sans-serif);
    color: var(--color-foreground, #1a1a1a);
  }

  .skpd-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  /* ── Media Column ── */
  .skpd-media-col {
    position: relative;
  }

  .skpd-media-sticky {
    position: sticky;
    top: 100px;   /* leave room for your fixed header */
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }

  /* ── Thumbnail Strip ── */
  .skpd-thumbnails {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex-shrink: 0;
    width: 72px;
    max-height: 440px;
    overflow-y: auto;
    scrollbar-width: none;
  }

  .skpd-thumbnails::-webkit-scrollbar { display: none; }

  .skpd-thumb {
    display: block;
    width: 72px;
    height: 72px;
    padding: 0;
    border: 2px solid transparent;
    border-radius: 4px;
    cursor: pointer;
    background: var(--color-background-secondary, #f5f5f5);
    overflow: hidden;
    transition: border-color 0.2s ease;
    flex-shrink: 0;
  }

  .skpd-thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .skpd-thumb--active,
  .skpd-thumb:hover {
    border-color: var(--color-foreground, #1a1a1a);
  }

  /* ── Main Image ── */
  .skpd-main-image {
    flex: 1;
    position: relative;
    background: var(--color-background-secondary, #f5f5f5);
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    min-height: 400px;
  }

  .skpd-slide {
    display: none;
    width: 100%;
    height: 100%;
  }

  .skpd-slide--active {
    display: block;
  }

  .skpd-main-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    transition: transform 0.4s ease;
  }

  .skpd-main-image:hover .skpd-main-img {
    transform: scale(1.04);
  }

  .skpd-placeholder-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ── Details Column ── */
  .skpd-details-col {
    padding-top: 8px;
  }

  .skpd-details-inner {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* ── Title ── */
  .skpd-title {
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.25;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  /* ── Price ── */
  .skpd-price-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .skpd-price {
    font-size: 1.3rem;
    font-weight: 700;
  }

  .skpd-price--sale {
    color: #d93838;
  }

  .skpd-price--compare {
    font-size: 1rem;
    font-weight: 400;
    text-decoration: line-through;
    opacity: 0.55;
    color: var(--color-foreground, #1a1a1a);
  }

  /* ── Divider ── */
  .skpd-divider {
    border: none;
    border-top: 1px solid var(--color-border, #e0e0e0);
    margin: 0;
  }

  /* ── Variant Dropdowns ── */
  .skpd-variants {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .skpd-option-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 6px;
    color: var(--color-foreground, #1a1a1a);
  }

  .skpd-select-wrap {
    position: relative;
    border: 1.5px solid var(--color-border, #d0d0d0);
    border-radius: 4px;
    background: var(--color-background, #fff);
    transition: border-color 0.2s;
  }

  .skpd-select-wrap:hover,
  .skpd-select-wrap:focus-within {
    border-color: var(--color-foreground, #1a1a1a);
  }

  .skpd-select {
    width: 100%;
    padding: 12px 40px 12px 14px;
    font-size: 0.9rem;
    color: var(--color-foreground, #1a1a1a);
    background: transparent;
    border: none;
    appearance: none;
    cursor: pointer;
    outline: none;
  }

  .skpd-caret {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    width: 10px;
    height: 6px;
    pointer-events: none;
    color: var(--color-foreground, #1a1a1a);
  }

  /* ── Qty + Add to Cart ── */
  .skpd-atc-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .skpd-qty-atc-row {
    display: flex;
    gap: 10px;
    align-items: stretch;
  }

  .skpd-qty-wrap {
    display: flex;
    align-items: center;
    border: 1.5px solid var(--color-border, #d0d0d0);
    border-radius: 4px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .skpd-qty-btn {
    width: 40px;
    height: 48px;
    background: transparent;
    border: none;
    font-size: 1.2rem;
    cursor: pointer;
    color: var(--color-foreground, #1a1a1a);
    transition: background 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .skpd-qty-btn:hover {
    background: var(--color-background-secondary, #f5f5f5);
  }

  .skpd-qty-input {
    width: 44px;
    height: 48px;
    text-align: center;
    border: none;
    border-left: 1.5px solid var(--color-border, #d0d0d0);
    border-right: 1.5px solid var(--color-border, #d0d0d0);
    font-size: 0.95rem;
    color: var(--color-foreground, #1a1a1a);
    background: transparent;
    -moz-appearance: textfield;
    outline: none;
  }

  .skpd-qty-input::-webkit-outer-spin-button,
  .skpd-qty-input::-webkit-inner-spin-button {
    display: none;
  }

  .skpd-atc-btn {
    flex: 1;
    height: 48px;
    background: #d93838;
    color: #fff;
    border: none;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: background 0.25s, transform 0.15s;
  }

  .skpd-atc-btn:hover:not(:disabled) {
    background: #b52e2e;
    transform: translateY(-1px);
  }

  .skpd-atc-btn:disabled {
    background: #ccc;
    cursor: not-allowed;
  }

  /* ── Dynamic Checkout (Buy Now) ── */
  .skpd-dynamic-checkout {
    margin-top: 0;
  }

  .skpd-dynamic-checkout .shopify-payment-button__button {
    border-radius: 4px !important;
    font-weight: 700 !important;
    letter-spacing: 0.05em !important;
  }

  /* ── Description ── */
  .skpd-description {
    font-size: 0.92rem;
    line-height: 1.7;
    color: var(--color-foreground, #1a1a1a);
    opacity: 0.85;
  }

  .skpd-description ul,
  .skpd-description ol {
    padding-left: 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .skpd-description li::marker {
    color: #d93838;
  }

  /* ── Share ── */
  .skpd-share {
    display: flex;
    align-items: center;
    gap: 8px;
    padding-top: 4px;
  }

  .skpd-share-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--color-foreground, #1a1a1a);
    opacity: 0.6;
    transition: opacity 0.2s;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .skpd-share-btn:hover {
    opacity: 1;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .skpd-container {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .skpd-media-sticky {
      position: relative;
      top: auto;
    }
  }

  @media (max-width: 600px) {
    .skpd-media-sticky {
      flex-direction: column-reverse;
    }

    .skpd-thumbnails {
      flex-direction: row;
      width: 100%;
      max-height: none;
      overflow-x: auto;
    }

    .skpd-thumb {
      width: 60px;
      height: 60px;
      flex-shrink: 0;
    }

    .skpd-title {
      font-size: 1.2rem;
    }
  }
</style>

{% comment %} ═══════ JAVASCRIPT ═══════ {% endcomment %}
<script>
(function () {
  var sectionId = {{ section.id | json }};
  var prefix    = 'skpd-' + sectionId;

  document.addEventListener('DOMContentLoaded', function () {

    /* ─── Auto-detect header height and set padding-top ─── */
    function syncHeaderOffset() {
      var header = document.querySelector('.sketch-header-unique');
      if (header) {
        var h = header.getBoundingClientRect().height;
        document.body.style.setProperty('--skpd-header-offset', h + 'px');
      }
    }
    syncHeaderOffset();
    window.addEventListener('resize', syncHeaderOffset);


    var thumbContainer = document.getElementById('skpd-thumbs-' + sectionId);
    var mainContainer  = document.getElementById('skpd-main-' + sectionId);

    if (thumbContainer && mainContainer) {
      var thumbs = thumbContainer.querySelectorAll('.skpd-thumb');
      var slides = mainContainer.querySelectorAll('.skpd-slide');

      function showSlide(index) {
        thumbs.forEach(function(t) { t.classList.remove('skpd-thumb--active'); });
        slides.forEach(function(s) { s.classList.remove('skpd-slide--active'); });
        if (thumbs[index]) thumbs[index].classList.add('skpd-thumb--active');
        if (slides[index]) slides[index].classList.add('skpd-slide--active');
      }

      thumbs.forEach(function(thumb) {
        thumb.addEventListener('click', function () {
          showSlide(parseInt(this.dataset.index, 10));
        });
      });
    }

    /* ─── Variant picker ─── */
    var variantsJson = document.getElementById('skpd-variants-json-' + sectionId);
    if (!variantsJson) return;

    var allVariants = JSON.parse(variantsJson.textContent);
    var form        = document.getElementById('skpd-form-' + sectionId);
    var variantInput = document.getElementById('skpd-variant-id-' + sectionId);
    var priceWrap   = document.getElementById('skpd-price-' + sectionId);
    var atcBtn      = document.getElementById('skpd-atc-' + sectionId);
    var selects     = (document.getElementById('skpd-variants-' + sectionId) || {}).querySelectorAll
      ? document.getElementById('skpd-variants-' + sectionId).querySelectorAll('.skpd-select')
      : [];

    function getSelectedOptions() {
      return Array.from(selects).map(function(sel) { return sel.value; });
    }

    function findMatchingVariant(selectedOptions) {
      return allVariants.find(function(variant) {
        return variant.options.every(function(opt, i) {
          return opt === selectedOptions[i];
        });
      });
    }

    function formatMoney(cents) {
      var amount = (cents / 100).toFixed(2);
      return window.Shopify && window.Shopify.currency
        ? window.Shopify.currency.active + '\u00a0' + amount
        : '\u20ac' + amount;
    }

    function updatePrice(variant) {
      if (!priceWrap) return;
      var html = '';
      if (variant.compare_at_price && variant.compare_at_price > variant.price) {
        html += '<span class="skpd-price skpd-price--sale">' + formatMoney(variant.price) + '</span>';
        html += '<span class="skpd-price skpd-price--compare">' + formatMoney(variant.compare_at_price) + '</span>';
      } else {
        html += '<span class="skpd-price">' + formatMoney(variant.price) + '</span>';
      }
      priceWrap.innerHTML = html;
    }

    function updateMainImage(variant) {
      if (!variant.featured_image) return;
      // Find the slide whose src matches (or closest)
      var imgId = variant.featured_image.id;
      var slides = mainContainer ? mainContainer.querySelectorAll('.skpd-slide') : [];
      slides.forEach(function(slide, idx) {
        var img = slide.querySelector('img');
        if (!img) return;
        // Match by checking if the URL contains the media ID
        var src = img.src || '';
        if (src.indexOf('/' + imgId + '/') !== -1 || src.indexOf('_' + imgId + '.') !== -1) {
          showSlide(idx);
        }
      });
    }

    function onVariantChange() {
      var selected = getSelectedOptions();
      var variant  = findMatchingVariant(selected);
      if (!variant) return;

      variantInput.value = variant.id;
      updatePrice(variant);

      if (atcBtn) {
        if (variant.available) {
          atcBtn.disabled = false;
          atcBtn.textContent = {{ 'products.product.add_to_cart' | t | json }};
        } else {
          atcBtn.disabled = true;
          atcBtn.textContent = {{ 'products.product.sold_out' | t | json }};
        }
      }

      updateMainImage(variant);
    }

    Array.from(selects).forEach(function(sel) {
      sel.addEventListener('change', onVariantChange);
    });

    /* ─── Quantity ─── */
    var qtyWrap = document.querySelector('#skpd-form-' + sectionId + ' .skpd-qty-wrap');
    if (qtyWrap) {
      var qtyInput = qtyWrap.querySelector('.skpd-qty-input');
      qtyWrap.querySelector('.skpd-qty-minus').addEventListener('click', function () {
        var val = parseInt(qtyInput.value, 10);
        if (val > 1) qtyInput.value = val - 1;
      });
      qtyWrap.querySelector('.skpd-qty-plus').addEventListener('click', function () {
        var val = parseInt(qtyInput.value, 10);
        var max = parseInt(qtyInput.max, 10) || 999;
        if (val < max) qtyInput.value = val + 1;
      });
    }

  }); // DOMContentLoaded
})();
</script>

{% schema %}
{
  "name": "Sketch Product Detail",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Sketch Product Detail"
    }
  ]
}
{% endschema %}
