<section class="sk-product-grid-wrapper" id="sk-grid-{{ section.id }}">
  <div class="sk-pg-container">
    <div class="sk-pg-header">
      <h2 class="sk-pg-heading">{{ section.settings.title }}</h2>
    </div>
    {% assign products_to_show = section.settings.products_to_show | default: 4 %}
    {% paginate collections.all.products by products_to_show %}
      <div class="sk-pg-grid">
        {% for product in collections.all.products %}
          <div class="sk-pg-item">
            <a href="{{ product.url }}" class="sk-pg-card-link">
              <div class="sk-pg-image-wrapper">
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.title | escape }}"
                  loading="lazy"
                  class="sk-pg-image">
              </div>
              <div class="sk-pg-info">
                <h3 class="sk-pg-product-title">{{ product.title }}</h3>
                <span class="sk-pg-product-price" style="color: {{ section.settings.price_color }};">
                  {{ product.price | money }}
                </span>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>

      {% if section.settings.button_url != blank %}
        <div class="sk-pg-view-all-wrapper">
          <a href="{{ section.settings.button_url }}" class="sk-pg-view-all-button">
            {{ section.settings.button_text | default: "View All" }}
          </a>
        </div>
      {% elsif paginate.next %}
        <div class="sk-pg-view-all-wrapper">
          <a href="{{ paginate.next.url }}" class="sk-pg-view-all-button" id="sk-pg-load-more">
            {{ section.settings.button_text | default: "Load More" }}
          </a>
        </div>
      {% endif %}
    {% endpaginate %}

  </div>

</section>

<style>
.sk-product-grid-wrapper {
  padding: 60px 0;
  background: #fff;
  font-family: Arial, sans-serif;
}

.sk-pg-container {
  max-width: 1240px;
  margin: auto;
  position: relative;
}

.sk-pg-header {
  text-align: center;
  margin-bottom: 40px;
}

.sk-pg-heading {
  font-size: 28px;
  font-weight: 600;
  text-transform: uppercase;
}

.sk-pg-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 30px;
}

.sk-pg-item {
  position: relative;
  overflow: hidden;
}

.sk-pg-image-wrapper {
  background: #f0f0f0;
  aspect-ratio: 4/5;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.sk-pg-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: transform 0.4s ease;
}

.sk-pg-card-link:hover .sk-pg-image {
  transform: scale(1.05);
}

.sk-pg-info {
  text-align: center;
  margin-top: 10px;
}

.sk-pg-product-title {
  font-size: 11px;
  text-transform: uppercase;
  font-weight: 600;
}

.sk-pg-product-price {
  font-size: 13px;
  font-weight: 600;
}

.sk-pg-view-all-wrapper {
  text-align: center;
  margin-top: 40px;
}

.sk-pg-view-all-button {
  background-color: #000;
  color: #fff;
  border: none;
  padding: 10px 30px;
  font-size: 14px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background-color 0.3s ease;
}

.sk-pg-view-all-button:hover {
  background-color: #333;
}

/* Tablet */
@media(max-width:1024px){
  .sk-pg-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

/* Mobile */
@media(max-width:768px){
  .sk-pg-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media(max-width:480px){
  .sk-pg-grid {
    grid-template-columns: 1fr;
    padding:0 20px;
  }
  .sk-pg-image-wrapper{aspect-ratio: 5/5;}
}
</style>

<script type="module">
  document.addEventListener("DOMContentLoaded", function () {
    const gridWrapper = document.querySelector("#sk-grid-{{ section.id }}");
    if (!gridWrapper) return;

    const loadMoreBtn = document.getElementById("sk-pg-load-more");
    if(loadMoreBtn){
      loadMoreBtn.addEventListener("click", function(e) {
        e.preventDefault();
        const url = this.href;
        fetch(url + '&section_id={{ section.id }}')
        .then(res => res.text())
        .then(data => {
          const parser = new DOMParser();
          const html = parser.parseFromString(data, 'text/html');
          const newProducts = html.querySelectorAll('.sk-pg-item');
          const grid = document.querySelector('.sk-pg-grid');
          newProducts.forEach(product => grid.appendChild(product));
          
          const newBtn = html.getElementById('sk-pg-load-more');
          if(newBtn) {
            loadMoreBtn.href = newBtn.href;
          } else {
            loadMoreBtn.style.display = 'none';
          }
        });
      });
    }
  });
</script>

{% schema %}
{
  "name": "Sketch Product Grid",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "Featured Products" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 4, "max": 12, "step": 4, "default": 4 },
    { "type": "color", "id": "price_color", "label": "Price Color", "default": "#d93838" },
    { "type": "text", "id": "button_text", "label": "Button Label" },
    { "type": "url", "id": "button_url", "label": "Button Link" }
  ],
  "presets": [
    { "name": "Sketch Product Grid" }
  ]
}
{% endschema %}
