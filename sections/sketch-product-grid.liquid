<section class="sk-product-grid-wrapper" id="sk-grid-{{ section.id }}">
  <div class="sk-pg-container">
    <div class="sk-pg-header">
      <h2 class="sk-pg-heading">{{ section.settings.title }}</h2>
    </div>
    {% assign products_to_show = section.settings.products_to_show | default: 4 %}
    {% paginate collections.all.products by products_to_show %}
      <div class="sk-pg-grid">
        {% for product in collections.all.products %}
          <div class="sk-pg-item">
            <a href="{{ product.url }}" class="sk-pg-card-link">
              <div class="sk-pg-image-wrapper">
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.title | escape }}"
                  loading="lazy"
                  class="sk-pg-image">
              </div>
              <div class="sk-pg-info">
                <h3 class="sk-pg-product-title">{{ product.title }}</h3>
                <span class="sk-pg-product-price" style="color: {{ section.settings.price_color }};">
                  {{ product.price | money }}
                </span>
              </div>
            </a>
            <button class="sk-pg-quick-view-button" data-product-handle="{{ product.handle }}">Quick View</button>
          </div>
        {% endfor %}
      </div>

      {% if section.settings.button_url != blank %}
        <div class="sk-pg-view-all-wrapper">
          <a href="{{ section.settings.button_url }}" class="sk-pg-view-all-button">
            {{ section.settings.button_text | default: "View All" }}
          </a>
        </div>
      {% elsif paginate.next %}
        <div class="sk-pg-view-all-wrapper">
          <a href="{{ paginate.next.url }}" class="sk-pg-view-all-button" id="sk-pg-load-more">
            {{ section.settings.button_text | default: "Load More" }}
          </a>
        </div>
      {% endif %}
    {% endpaginate %}

  </div>

  <div id="sk-pg-quick-view-modal" class="sk-pg-modal">
    <div class="sk-pg-modal-content">
      <span class="sk-pg-modal-close">&times;</span>
      <div id="sk-pg-modal-body">
        </div>
        <div id="sk-pg-success-message" style="display: none; background-color: #4CAF50; color: white; padding: 10px; text-align: center; position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); border-radius: 5px;">
            Product added to cart successfully!
        </div>
    </div>
  </div>
</section>

<style>
.sk-product-grid-wrapper {
  padding: 60px 0;
  background: #fff;
  font-family: Arial, sans-serif;
}

.sk-pg-container {
  max-width: 1240px;
  margin: auto;
  position: relative;
}

.sk-pg-header {
  text-align: center;
  margin-bottom: 40px;
}

.sk-pg-heading {
  font-size: 28px;
  font-weight: 600;
  text-transform: uppercase;
}

.sk-pg-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 30px;
}

.sk-pg-item {
  position: relative;
  overflow: hidden;
}

.sk-pg-quick-view-button {
  position: absolute;
  bottom: 10px;
  left: 50%;
  transform: translateX(-50%);
  background-color: #fff;
  color: #000;
  border: 1px solid #000;
  padding: 5px 15px;
  font-size: 12px;
  text-transform: uppercase;
  cursor: pointer;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.sk-pg-item:hover .sk-pg-quick-view-button {
  opacity: 1;
}

.sk-pg-modal {
  display: none;
  position: fixed;
  z-index: 100;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  overflow: auto;
  background-color: rgba(0,0,0,0.4);
}

.sk-pg-modal-content {
  background-color: #fefefe;
  margin: 15% auto;
  padding: 20px;
  border: 1px solid #888;
  width: 80%;
  max-width: 600px;
  position: relative;
}

.sk-pg-modal-close {
  color: #aaa;
  float: right;
  font-size: 28px;
  font-weight: bold;
}

.sk-pg-modal-close:hover,
.sk-pg-modal-close:focus {
  color: black;
  text-decoration: none;
  cursor: pointer;
}

.sk-pg-image-wrapper {
  background: #f0f0f0;
  aspect-ratio: 4/5;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.sk-pg-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: transform 0.4s ease;
}

.sk-pg-card-link:hover .sk-pg-image {
  transform: scale(1.05);
}

.sk-pg-info {
  text-align: center;
  margin-top: 10px;
}

.sk-pg-product-title {
  font-size: 11px;
  text-transform: uppercase;
  font-weight: 600;
}

.sk-pg-product-price {
  font-size: 13px;
  font-weight: 600;
}

.sk-pg-view-all-wrapper {
  text-align: center;
  margin-top: 40px;
}

.sk-pg-view-all-button {
  background-color: #000;
  color: #fff;
  border: none;
  padding: 10px 30px;
  font-size: 14px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background-color 0.3s ease;
}

.sk-pg-view-all-button:hover {
  background-color: #333;
}

/* Tablet */
@media(max-width:1024px){
  .sk-pg-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

/* Mobile */
@media(max-width:768px){
  .sk-pg-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media(max-width:480px){
  .sk-pg-grid {
    grid-template-columns: 1fr;
    padding:0 20px;
  }
  .sk-pg-image-wrapper{aspect-ratio: 5/5;}
}
</style>

<script type="module">
  import { formatMoney } from '{{ 'money-formatting.js' | asset_url }}';

  document.addEventListener("DOMContentLoaded", function () {
    const gridWrapper = document.querySelector("#sk-grid-{{ section.id }}");
    if (!gridWrapper) return;

    const quickViewButtons = gridWrapper.querySelectorAll(".sk-pg-quick-view-button");
    const modal = document.getElementById("sk-pg-quick-view-modal");
    const modalBody = document.getElementById("sk-pg-modal-body");
    const closeModal = document.querySelector(".sk-pg-modal-close");

    const shopCurrency = '{{ cart.currency.iso_code }}';
    const moneyFormat = '{{ shop.money_format | replace: "'", "\\'" }}';

    function attachQuickViewEvents(buttons) {
      buttons.forEach(button => {
        button.addEventListener("click", openQuickView);
      });
    }

    attachQuickViewEvents(quickViewButtons);

    function openQuickView(event) {
      const productHandle = event.target.dataset.productHandle;
      fetch(`/products/${productHandle}.js`)
        .then(response => response.json())
        .then(product => {
          modalBody.innerHTML = `
            <div style="display: flex; gap: 20px;">
                <div style="flex: 1;">
                    <img src="${product.featured_image}" alt="${product.title}" style="max-width: 100%; height: auto;">
                </div>
                <div style="flex: 1;">
                    <h2>${product.title}</h2>
                    <p>${formatMoney(product.price, moneyFormat, shopCurrency)}</p>
                    <div>${product.description}</div>
                    <div style="margin-top: 20px;">
                        <input type="number" id="sk-pg-quantity" value="1" min="1" style="width: 60px; text-align: center;">
                        <button id="sk-pg-add-to-cart" data-product-id="${product.variants[0].id}">Add to Cart</button>
                    </div>
                </div>
            </div>
          `;
          modal.style.display = "block";

          const addToCartButton = document.getElementById("sk-pg-add-to-cart");
          addToCartButton.addEventListener("click", () => {
            const quantity = document.getElementById("sk-pg-quantity").value;
            const productId = addToCartButton.dataset.productId;

            fetch('/cart/add.js', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({
                items: [{
                  id: productId,
                  quantity: quantity
                }]
              })
            })
            .then(response => response.json())
            .then(cart => {
                document.dispatchEvent(new CustomEvent('cart:update', {
                    bubbles: true,
                    detail: { cart }
                }));
                const successMessage = document.getElementById("sk-pg-success-message");
                successMessage.style.display = "block";
                setTimeout(() => {
                    successMessage.style.display = "none";
                    modal.style.display = "none";
                }, 2000);
            });
          });
        });
    }

    closeModal.onclick = function() {
      modal.style.display = "none";
    }

    window.onclick = function(event) {
      if (event.target == modal) {
        modal.style.display = "none";
      }
    }

    const loadMoreBtn = document.getElementById("sk-pg-load-more");
    if(loadMoreBtn){
      loadMoreBtn.addEventListener("click", function(e) {
        e.preventDefault();
        const url = this.href;
        fetch(url + '&section_id={{ section.id }}')
        .then(res => res.text())
        .then(data => {
          const parser = new DOMParser();
          const html = parser.parseFromString(data, 'text/html');
          const newProducts = html.querySelectorAll('.sk-pg-item');
          const grid = document.querySelector('.sk-pg-grid');
          newProducts.forEach(product => grid.appendChild(product));
          
          const newBtn = html.getElementById('sk-pg-load-more');
          if(newBtn) {
            loadMoreBtn.href = newBtn.href;
          } else {
            loadMoreBtn.style.display = 'none';
          }
          
          const newQuickViewButtons = [];
          newProducts.forEach(p => {
            const btn = p.querySelector('.sk-pg-quick-view-button');
            if(btn) newQuickViewButtons.push(btn);
          });
          attachQuickViewEvents(newQuickViewButtons);
        });
      });
    }
  });
</script>

{% schema %}
{
  "name": "Sketch Product Grid",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "Featured Products" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 4, "max": 12, "step": 4, "default": 4 },
    { "type": "color", "id": "price_color", "label": "Price Color", "default": "#d93838" },
    { "type": "text", "id": "button_text", "label": "Button Label" },
    { "type": "url", "id": "button_url", "label": "Button Link" }
  ],
  "presets": [
    { "name": "Sketch Product Grid" }
  ]
}
{% endschema %}
