{% comment %}
  SKETCH SHIRTS CUSTOM HEADER
  This section is self-contained and uses unique class names to avoid 
  conflicting with your existing theme styles.
{% endcomment %}

<section class="sketch-header-unique" data-section-id="{{ section.id }}" style="background-color: {{ section.settings.bg_color }};">
  
  {%- if section.settings.show_announcement -%}
    <div class="sk-announcement-bar" style="background-color: {{ section.settings.announcement_bg_color }}; color: {{ section.settings.announcement_text_color }};">
      <div class="sk-container">
        {{ section.settings.announcement_text }}
      </div>
    </div>
  {%- endif -%}

  <header class="sk-main-nav">
    <div class="sk-container">
      <div class="sk-grid-top">
        <div class="sk-align-left">
          <a href="{{ routes.cart_url }}" class="sk-icon-link">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          </a>
        </div>

        <div class="sk-align-center">
          <a href="{{ routes.root_url }}">
            {%- if section.settings.logo != blank -%}
              <img src="{{ section.settings.logo | image_url: width: 400 }}" 
                   alt="{{ shop.name }}" 
                   style="max-height: {{ section.settings.logo_height }}px; width: auto;">
            {%- else -%}
              <h1 class="sk-logo-text">{{ shop.name }}</h1>
            {%- endif -%}
          </a>
        </div>

        <div class="sk-align-right">
          <a href="{{ routes.search_url }}" class="sk-icon-link">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </a>
        </div>
      </div>

      <nav class="sk-nav-wrapper">
        <ul class="sk-menu">
          {%- for link in section.settings.menu.links -%}
            <li class="sk-menu-item">
              <a href="{{ link.url }}" class="sk-link {% if link.current %}active{% endif %}">
                {{ link.title }}
                {%- if link.links != blank -%}
                  <span class="sk-caret">▼</span>
                {%- endif -%}
              </a>
              {%- if link.links != blank -%}
                <ul class="sk-dropdown">
                  {%- for childlink in link.links -%}
                    <li><a href="{{ childlink.url }}">{{ childlink.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    </div>
  </header>
</section>

<style>
/* Reset-scope to ensure theme defaults don't interfere */
.sketch-header-unique {
  width: 100%;
  margin: 0;
  padding: 0;
  font-family: inherit;
  line-height: 1.5;
}

.sketch-header-unique .sk-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 15px;
}

/* Announcement Bar */
.sketch-header-unique .sk-announcement-bar {
  text-align: center;
  padding: 10px 0;
  font-size: 12px;
  letter-spacing: 0.1em;
  font-weight: 600;
  text-transform: uppercase;
}

/* Grid Layout */
.sketch-header-unique .sk-grid-top {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  padding: 20px 0;
}

.sketch-header-unique .sk-align-left { justify-self: start; }
.sketch-header-unique .sk-align-center { justify-self: center; }
.sketch-header-unique .sk-align-right { justify-self: end; }

.sketch-header-unique .sk-icon-link {
  color: {{ section.settings.text_color }};
  text-decoration: none;
}

.sketch-header-unique .sk-logo-text {
  color: {{ section.settings.text_color }};
  margin: 0;
  font-size: 24px;
}

/* Navigation Menu */
.sketch-header-unique .sk-nav-wrapper {
  padding-bottom: 20px;
}

.sketch-header-unique .sk-menu {
  display: flex;
  justify-content: center;
  list-style: none;
  margin: 0;
  padding: 0;
  gap: 30px;
}

.sketch-header-unique .sk-menu-item {
  position: relative;
}

.sketch-header-unique .sk-link {
  text-decoration: none;
  color: {{ section.settings.text_color }};
  font-size: 13px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  display: flex;
  align-items: center;
  gap: 5px;
}

.sketch-header-unique .sk-caret {
  font-size: 8px;
}

/* Simple Dropdown */
.sketch-header-unique .sk-dropdown {
  display: none;
  position: absolute;
  top: 100%;
  left: 0;
  background: #fff;
  color: #000;
  min-width: 180px;
  box-shadow: 0 5px 15px rgba(0,0,0,0.1);
  padding: 10px 0;
  z-index: 99;
}

.sketch-header-unique .sk-menu-item:hover .sk-dropdown {
  display: block;
}

.sketch-header-unique .sk-dropdown a {
  display: block;
  padding: 8px 20px;
  text-decoration: none;
  color: #000;
  font-size: 12px;
}

.sketch-header-unique .sk-dropdown a:hover {
  background: #f4f4f4;
}

/* Responsive */
@media (max-width: 768px) {
  .sketch-header-unique .sk-menu {
    gap: 15px;
    font-size: 11px;
    flex-wrap: wrap;
  }
}
</style>

{% schema %}
{
  "name": "Sketch Custom Header",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text/Icon Color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show Announcement Bar",
      "default": true
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement Text",
      "default": "FREE SHIPPING FROM 30€"
    },
    {
      "type": "color",
      "id": "announcement_bg_color",
      "label": "Announcement Background",
      "default": "#e6d5d0"
    },
    {
      "type": "color",
      "id": "announcement_text_color",
      "label": "Announcement Text Color",
      "default": "#000000"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 20,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Logo Height",
      "default": 50
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation Menu",
      "default": "main-menu"
    }
  ],
  "presets": [
    {
      "name": "Sketch Custom Header"
    }
  ]
}
{% endschema %}