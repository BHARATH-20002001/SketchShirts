{% comment %}
  Custom Header Section
  - Includes Logo, Navigation, and basic styling.
{% endcomment %}

<style>
  .custom-header-wrapper {
    background-color: {{ section.settings.bg_color }};
    padding: 10px 20px;
    border-bottom: 1px solid #e0e0e0;
  }

  .custom-header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Logo Styling */
  .header-logo img {
    max-width: {{ section.settings.logo_width }}px;
    height: auto;
    display: block;
  }
  .header-logo-text {
    font-size: 24px;
    font-weight: bold;
    text-decoration: none;
    color: #333;
  }

  /* Navigation Styling */
  .header-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 20px;
  }

  .header-nav a {
    text-decoration: none;
    color: #333;
    font-size: 16px;
    font-weight: 500;
  }

  .header-nav a:hover {
    color: #007ace; /* Example hover color */
  }
</style>

<header class="custom-header-wrapper">
  <div class="custom-header-container">
    
    <!-- 1. Logo Area -->
    <div class="header-logo">
      <a href="{{ routes.root_url }}">
        {% if section.settings.logo != blank %}
          {{ section.settings.logo | image_url: width: 300 | image_tag: loading: 'lazy', alt: shop.name }}
        {% else %}
          <span class="header-logo-text">{{ shop.name }}</span>
        {% endif %}
      </a>
    </div>

    <!-- 2. Navigation Area -->
    <nav class="header-nav">
      <ul>
        {% for link in section.settings.menu.links %}
          <li>
            <a href="{{ link.url }}">{{ link.title }}</a>
          </li>
        {% endfor %}
      </ul>
    </nav>

    <!-- 3. Icons / Actions (Optional placeholder) -->
    <div class="header-icons">
      <a href="{{ routes.cart_url }}">Cart</a>
      <a href="{{ routes.cart_url }}">
        Cart
        {%- if cart.item_count > 0 -%}
          <span>({{ cart.item_count }})</span>
        {%- endif -%}
      </a>
    </div>

  </div>
</header>

{% schema %}
{
  "name": "Custom Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 250,
      "step": 10,
      "default": 100,
      "unit": "px",
      "label": "Logo Width"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Custom Header"
    }
  ]
}
{% endschema %}
