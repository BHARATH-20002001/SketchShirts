{% comment %}
  SKETCH SHIRTS - CONTACT US PAGE SECTION
{% endcomment %}

<div class="sk-contact-wrapper" id="sk-contact-{{ section.id }}">
  
  {% comment %} ===== BANNER ===== {% endcomment %}
  <div class="sk-contact-banner">
    {% if section.settings.banner_image != blank %}
      <img src="{{ section.settings.banner_image | image_url: width: 2000 }}" alt="Contact Banner" class="sk-contact-banner-bg" loading="lazy">
    {% else %}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg sk-contact-banner-bg' }}
    {% endif %}
    
    <div class="sk-contact-overlay" style="background-color: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});"></div>
    
    <div class="sk-contact-banner-content">
      <h1 class="sk-contact-title">{{ section.settings.banner_heading }}</h1>
      {% if section.settings.banner_subheading != blank %}
        <a href="#" class="sk-contact-btn">{{ section.settings.banner_subheading }}</a>
      {% endif %}
    </div>
  </div>

  {% comment %} ===== CONTACT CONTENT ===== {% endcomment %}
  <div class="sk-contact-main">
    <div class="sk-contact-header">
      <h2 class="sk-contact-heading">{{ section.settings.main_heading }}</h2>
      {% if section.settings.main_subtext != blank %}
        <div class="sk-contact-subtext">{{ section.settings.main_subtext }}</div>
      {% endif %}
      
      {% if page.content != blank %}
        <div class="sk-contact-page-content">
          {{ page.content }}
        </div>
      {% endif %}
    </div>

    <div class="sk-contact-grid">
      
      {% comment %} --- LEFT: FORM --- {% endcomment %}
      <div class="sk-contact-form-col">
        {%- form 'contact', id: 'ContactForm' -%}
          {%- if form.posted_successfully? -%}
            <div class="sk-form-success">
              Vielen Dank für Ihre Nachricht. Wir werden uns so schnell wie möglich bei Ihnen melden.
            </div>
          {%- elsif form.errors -%}
            <div class="sk-form-error">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <div class="sk-form-row">
            <div class="sk-form-field">
              <input type="text" id="ContactFormName" name="contact[name]" placeholder="{{ section.settings.placeholder_name }}" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" required>
            </div>
            <div class="sk-form-field">
              <input type="email" id="ContactFormEmail" name="contact[email]" placeholder="{{ section.settings.placeholder_email }}" spellcheck="false" autocomplete="email" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" required>
            </div>
          </div>
          
          <div class="sk-form-field">
            <textarea id="ContactFormMessage" name="contact[body]" rows="6" placeholder="{{ section.settings.placeholder_message }}" required>{%- if form.body -%}{{ form.body }}{%- endif -%}</textarea>
          </div>
          
          <button type="submit" class="sk-contact-submit">{{ section.settings.submit_button }}</button>
        {%- endform -%}
      </div>

      {% comment %} --- RIGHT: INFO --- {% endcomment %}
      <div class="sk-contact-info-col">
        <div class="sk-info-block">
          <h4>{{ section.settings.address_heading }}</h4>
          <div class="sk-info-text">{{ section.settings.address_text }}</div>
        </div>
        
        <div class="sk-info-block">
          <h4>{{ section.settings.info_heading }}</h4>
          <div class="sk-info-text">{{ section.settings.info_text }}</div>
        </div>
        
        <div class="sk-info-block">
          <h4>{{ section.settings.social_heading }}</h4>
          <div class="sk-social-icons">
            <a href="{{ settings.social_instagram_link | default: '#' }}" target="_blank" aria-label="Instagram">
              <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-instagram" viewBox="0 0 512 512"><path d="M256 109.3c47.8 0 53.4 0.2 72.3 1 17.4 0.8 26.9 3.7 33.2 6.2 8.4 3.2 14.3 7.1 20.6 13.4 6.3 6.3 10.1 12.2 13.4 20.6 2.5 6.3 5.3 15.8 6.2 33.2 0.9 18.9 1 24.5 1 72.3s-0.2 53.4-1 72.3c-0.8 17.4-3.7 26.9-6.2 33.2-3.2 8.4-7.1 14.3-13.4 20.6-6.3 6.3-12.2 10.1-20.6 13.4-6.3 2.5-15.8 5.3-33.2 6.2-18.9 0.9-24.5 1-72.3 1s-53.4-0.2-72.3-1c-17.4-0.8-26.9-3.7-33.2-6.2-8.4-3.2-14.3-7.1-20.6-13.4-6.3-6.3-10.1-12.2-13.4-20.6-2.5-6.3-5.3-15.8-6.2-33.2-0.9-18.9-1-24.5-1-72.3s0.2-53.4 1-72.3c0.8-17.4 3.7-26.9 6.2-33.2 3.2-8.4 7.1-14.3 13.4-20.6 6.3-6.3 12.2-10.1 20.6-13.4 6.3-2.5 15.8-5.3 33.2-6.2 18.9-0.9 24.5-1 72.3-1m0-45.4c-48.6 0-54.7 0.2-73.8 1.1-19 0.9-32.1 3.9-43.4 8.3-11.8 4.6-21.7 10.7-31.7 20.6-9.9 9.9-16.1 19.9-20.6 31.7-4.4 11.3-7.4 24.4-8.3 43.4-0.9 19.1-1.1 25.2-1.1 73.8s0.2 54.7 1.1 73.8c0.9 19 3.9 32.1 8.3 43.4 4.6 11.8 10.7 21.7 20.6 31.7 9.9 9.9 19.9 16.1 31.7 20.6 11.3 4.4 24.4 7.4 43.4 8.3 19.1 0.9 25.2 1.1 73.8 1.1s54.7-0.2 73.8-1.1c19-0.9 32.1-3.9 43.4-8.3 11.8-4.6 21.7-10.7 31.7-20.6 9.9-9.9 16.1-19.9 20.6-31.7 4.4-11.3 7.4-24.4 8.3-43.4 0.9-19.1 1.1-25.2 1.1-73.8s-0.2-54.7-1.1-73.8c-0.9-19-3.9-32.1-8.3-43.4-4.6-11.8-10.7-21.7-20.6-31.7-9.9-9.9-19.9-16.1-31.7-20.6-11.3-4.4-24.4-7.4-43.4-8.3-19.1-0.9-25.2-1.1-73.8-1.1z"/><path d="M256 164.1c-50.7 0-91.9 41.1-91.9 91.9s41.1 91.9 91.9 91.9 91.9-41.1 91.9-91.9-41.1-91.9-91.9-91.9m0 138.4c-25.7 0-46.5-20.8-46.5-46.5s20.8-46.5 46.5-46.5 46.5 20.8 46.5 46.5-20.8 46.5-46.5 46.5"/><path d="M382.8 159.2c-12.5 0-22.6-10.1-22.6-22.6s10.1-22.6 22.6-22.6 22.6 10.1 22.6 22.6-10.1 22.6-22.6 22.6"/></svg>
            </a>
            <a href="{{ settings.social_facebook_link | default: '#' }}" target="_blank" aria-label="Facebook">
              <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-facebook" viewBox="0 0 512 512"><path d="M512 256C512 114.6 397.4 0 256 0S0 114.6 0 256c0 120.2 82.7 220.8 196 245.8V330H140v-74h56v-53.7c0-55.6 33.1-86.4 83.9-86.4 24.3 0 49.6 4.3 49.6 4.3v54.5h-28c-27.5 0-36.1 17.1-36.1 34.6V256h61.7l-9.9 74h-51.8v171.8C429.3 476.8 512 376.2 512 256z"/></svg>
            </a>
          </div>
        </div>
        
        <div class="sk-info-block">
          <h4>{{ section.settings.open_heading }}</h4>
          <div class="sk-info-text">{{ section.settings.open_text }}</div>
        </div>
      </div>
    
    </div>
  </div>
</div>

<style>
  .sk-contact-wrapper {
    width: 100%;
    background-color: #fff;
    font-family: var(--font-body--family, sans-serif);
  }

  /* Banner Styles */
  .sk-contact-banner {
    position: relative;
    width: 100%;
    height: 60vh;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  
  .sk-contact-banner-bg {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    object-fit: cover;
    z-index: 1;
  }
  
  .sk-contact-overlay {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    z-index: 2;
  }
  
  .sk-contact-banner-content {
    position: relative;
    z-index: 3;
    text-align: center;
    color: #fff;
    padding: 0 20px;
  }

  .sk-contact-title {
    font-family: var(--font-heading--family, 'Times New Roman', serif);
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 400;
    margin: 0;
    letter-spacing: 0.05em;
    text-shadow: 2px 2px 8px rgba(0,0,0,0.5);
    color: #fff;
  }

  .sk-contact-btn {
    display: inline-block;
    margin-top: 20px;
    padding: 10px 30px;
    border: 1px solid #fff;
    color: #fff;
    text-decoration: none;
    text-transform: uppercase;
    font-size: 14px;
    letter-spacing: 0.1em;
    transition: all 0.3s ease;
  }

  .sk-contact-btn:hover {
    background-color: #fff;
    color: #000;
  }

  /* Main Contact Section */
  .sk-contact-main {
    max-width: 1240px;
    margin: 0 auto;
    padding: 100px 0px;
  }

  .sk-contact-header {
    margin-bottom: 60px;
  }

  .sk-contact-heading {
    font-size: 28px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 20px 0;
    color: #000;
  }

  .sk-contact-subtext {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #333;
    line-height: 1.6;
    max-width: 600px;
  }

  .sk-contact-page-content {
    font-size: 14px;
    color: #222;
    line-height: 1.6;
    margin-top: 30px;
    max-width: 800px;
  }

  .sk-contact-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 80px;
  }

  /* Form Styles */
  .sk-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }
  
  .sk-form-field {
    width: 100%;
  }

  .sk-contact-form-col input[type="text"],
  .sk-contact-form-col input[type="email"],
  .sk-contact-form-col textarea {
    width: 100%;
    padding: 15px 20px;
    border: 1px solid #e0e0e0;
    background-color: transparent;
    font-family: inherit;
    font-size: 12px;
    color: #000;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    outline: none;
    transition: border-color 0.3s;
  }

  .sk-contact-form-col input::placeholder,
  .sk-contact-form-col textarea::placeholder {
    color: #999;
  }

  .sk-contact-form-col input:focus,
  .sk-contact-form-col textarea:focus {
    border-color: #000;
  }

  .sk-contact-form-col textarea {
    resize: vertical;
    margin-bottom: 30px;
  }

  .sk-contact-submit {
    display: inline-block;
    background-color: transparent;
    color: #000;
    border: 1px solid #000;
    padding: 15px 40px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .sk-contact-submit:hover {
    background-color: #000;
    color: #fff;
  }

  .sk-form-success {
    background-color: #f0fdf4;
    color: #166534;
    padding: 15px;
    margin-bottom: 30px;
    border: 1px solid #bbf7d0;
  }

  .sk-form-error {
    background-color: #fef2f2;
    color: #991b1b;
    padding: 15px;
    margin-bottom: 30px;
    border: 1px solid #fecaca;
  }

  /* Info Column Styles */
  .sk-contact-info-col {
    padding-left: 20px;
  }

  .sk-info-block {
    margin-bottom: 40px;
  }

  .sk-info-block h4 {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 15px 0;
    color: #000;
  }

  .sk-info-text {
    font-size: 12px;
    line-height: 1.8;
    color: #333;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .sk-social-icons {
    display: flex;
    gap: 15px;
    margin-top: 10px;
  }

  .sk-social-icons a {
    color: #000;
    display: block;
    width: 24px;
    height: 24px;
    transition: opacity 0.3s;
  }
  
  .sk-social-icons a:hover {
    opacity: 0.6;
  }
  
  .sk-social-icons svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  /* Responsive Design */
  @media (max-width: 990px) {
    .sk-contact-grid {
      grid-template-columns: 1fr;
      gap: 60px;
    }
    .sk-contact-info-col {
      padding-left: 0;
    }
  }

  @media (max-width: 768px) {
    .sk-form-row {
      grid-template-columns: 1fr;
    }
    .sk-contact-main {
      padding: 60px 20px;
    }
  }
</style>

{% schema %}
{
  "name": "Contact Page",
  "settings": [
    {
      "type": "header",
      "content": "Banner"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Background Image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Banner Darkening Overlay",
      "default": 30
    },
    {
      "type": "text",
      "id": "banner_heading",
      "label": "Banner Heading",
      "default": "KONTAKT"
    },
    {
      "type": "text",
      "id": "banner_subheading",
      "label": "Banner Button/Subheading",
      "default": "ABSENDEN"
    },
    {
      "type": "header",
      "content": "Contact Details"
    },
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main Heading",
      "default": "WE WOULD LOVE TO HEAR FROM YOU."
    },
    {
      "type": "richtext",
      "id": "main_subtext",
      "label": "Main Subtext",
      "default": "<p>IF YOU'VE GOT GREAT PRODUCTS YOUR MAKING OR LOOKING TO WORK WITH US THEN DROP US A LINE.</p>"
    },
    {
      "type": "header",
      "content": "Form Labels"
    },
    {
      "type": "text",
      "id": "placeholder_name",
      "label": "Name Placeholder",
      "default": "NAME"
    },
    {
      "type": "text",
      "id": "placeholder_email",
      "label": "Email Placeholder",
      "default": "EMAIL"
    },
    {
      "type": "text",
      "id": "placeholder_message",
      "label": "Message Placeholder",
      "default": "MESSAGE"
    },
    {
      "type": "text",
      "id": "submit_button",
      "label": "Submit Button Text",
      "default": "ABSENDEN"
    },
    {
      "type": "header",
      "content": "Info Panel"
    },
    {
      "type": "text",
      "id": "address_heading",
      "label": "Address Heading",
      "default": "ADDRESS"
    },
    {
      "type": "richtext",
      "id": "address_text",
      "label": "Address Text",
      "default": "<p>1895 RIGHTEOUS INDIGNATION AND DISLIKE,<br/>SEE OUR STORE</p>"
    },
    {
      "type": "text",
      "id": "info_heading",
      "label": "Information Heading",
      "default": "INFORMATION"
    },
    {
      "type": "richtext",
      "id": "info_text",
      "label": "Information Text",
      "default": "<p>+91 123 456 7890<br/>SKETCH SHIRT.com</p>"
    },
    {
      "type": "text",
      "id": "social_heading",
      "label": "Social Media Heading",
      "default": "SOCIAL MEDIA"
    },
    {
      "type": "text",
      "id": "open_heading",
      "label": "Opening Hours Heading",
      "default": "WE'RE OPEN"
    },
    {
      "type": "richtext",
      "id": "open_text",
      "label": "Opening Hours",
      "default": "<p>ET HARUM QUIDEM RERUM FACILIS EST ET EXPEDITA DISTINCTIO.</p>"
    }
  ],
  "presets": [
    {
      "name": "Contact Page"
    }
  ]
}
{% endschema %}
